{
	"name": "textreplacer-userscript",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build:textreplacer": "cd textreplacer && npm run build",
		"build:configure": "cd configure && npm run build",
		"dev:textreplacer": "cd textreplacer && npm run dev",
		"dev:configure": "cd configure && npm run dev",
		"test:textreplacer": "cd textreplacer && npm test",
		"test:configure": "cd configure && npm test",
		"typecheck": "tsc --watch --noEmit",
		"lint": "biome check",
		"lintFix": "biome check --write",
		"test": "npm run test:textreplacer && npm run test:configure"
	},
	"dependencies": {},
	"devDependencies": {
		"typescript": "^6.0.3"
	}
}
